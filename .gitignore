MemoryCaptures/
Build/
Builds/
Assets/Plugins/Editor/

# Ignore autogenerated Unity files
*.csproj
*.unityproj
*.sln
*.user
*.pidb
*.booproj
*.svd
*.pdb
*.mdb

# ---- System junk ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Backups ----
*.bak
*.tmp
*.old

# ---- Python virtual env test folders ----
*.pytest_cache/
.cache/

# ---- Git keepers (preserve folders) ----
!.gitkeep
