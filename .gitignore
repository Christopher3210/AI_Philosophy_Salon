# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyi
*.pyd
*.egg-info/
.env
.venv/

# ---- VSCode ----
.vscode/
.history/
*.code-workspace

# ---- LM Studio ----
lmstudio-cache/
lmstudio-temp/
